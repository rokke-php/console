{
	"name": "rokke/console",
	"description": "Console transport adapter for the Rokke Runtime — routes CLI commands to compiled operations",
	"type": "library",
	"license": "MIT",
	"authors": [
		{
			"name": "Fernando Duarte",
			"email": "fduarte@rokke.dev"
		}
	],
	"keywords": [
		"cli",
		"console",
		"rokke",
		"php"
	],
	"homepage": "https://rokke.dev",
	"support": {
		"issues": "https://github.com/rokke-php/console/issues",
		"source": "https://github.com/rokke-php/console"
	},
	"version": "0.3.0",
	"require": {
		"php": ">=8.4",
		"rokke/contracts": "^0.7.0",
		"rokke/runtime": "^0.19.0"
	},
	"require-dev": {
		"friendsofphp/php-cs-fixer": "^3.64",
		"phpstan/phpstan": "^1.12",
		"phpstan/phpstan-phpunit": "^1.4",
		"phpunit/phpunit": "^13.0"
	},
	"autoload": {
		"psr-4": {
			"Rokke\\Console\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Rokke\\Console\\Tests\\": "tests/"
		}
	},
	"config": {
		"optimize-autoloader": true,
		"sort-packages": true,
		"preferred-install": "dist",
		"allow-plugins": {}
	},
	"scripts": {
		"test": "phpunit",
		"lint": "php-cs-fixer fix --dry-run --diff --verbose",
		"lint:fix": "php-cs-fixer fix",
		"analyse": "phpstan analyse --memory-limit=2G",
		"check": [
			"@lint",
			"@analyse",
			"@test"
		]
	},
	"minimum-stability": "stable",
	"prefer-stable": true
}
